    {
      "name": "Topics",
      "item": [
        {
          "name": "GET /api/topics (sets topicId)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/topics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "topics"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const topics = pm.response.json();",
                  "if (Array.isArray(topics) && topics.length) {",
                  "  const pick = topics.find(t => t && t.subscribed === false) || topics[0];",
                  "  if (pick?.id != null) pm.environment.set('topicId', pick.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
